# TryBello Funnelish-Shopify Sync — Environment Variables
# Set these in Railway service variables (never commit .env to git)

FUNNELISH_EMAIL=assistant@trybello.com
FUNNELISH_PASSWORD=your_funnelish_password

SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret
SHOPIFY_SHOP=trybello.myshopify.com

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_CHANNEL=#trybello-cs-alert
SLACK_CS_USER_ID=U0ABB3AV2E8
SLACK_SIGNING_SECRET=your_slack_signing_secret

GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/...
GOOGLE_SHEET_ID=your_sheet_id

PORT=8080
